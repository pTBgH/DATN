# Vault initialization output (root token + recovery keys) — F-2 audit fix.
# Generated by infras/k8s-yaml/vault-scripts/99-fast-rebuild-vault.sh.
infras/k8s-yaml/vault-scripts/vault-prod-init.json
**/vault-prod-init.json
**/vault-init-*.json

# Generated TLS / token / kubeconfig artifacts
**/vault-tls-*.pem
**/vault-ca.crt
**/.vault-token

# Evidence / baseline directories from PR #7 observability tool
evidence/baseline-*/
evidence/audit-*/

# Cilium policy dry-run dumps
*.dryrun.yaml

# Local environment files (Laravel + frontends)
**/.env.local
**/.env.development.local
.env
.env.*.local

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Misc runtime
*.log
*.pid
node_modules/
vendor/

# Pre-existing entry retained:
# (vault-scripts/.gitignore already has vault-prod-init.json)
