# --- Public (exposed to browser) ---

# Mock-only mode: every API call short-circuits to in-memory mock fixtures.
NEXT_PUBLIC_USE_MOCK=true

# Kong gateway base URL — only used when NEXT_PUBLIC_USE_MOCK=false.
NEXT_PUBLIC_API_BASE_URL=https://api.job7189.com
NEXT_PUBLIC_API_HOST_OVERRIDE=

# Keycloak (realm `job7189`).
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.job7189.com
NEXT_PUBLIC_KEYCLOAK_REALM=job7189
# atd (applicant) logs in as the candidate public client so the token's `azp`
# matches identity-service's KEYCLOAK_CANDIDATE_CLIENT_ID. Must be a PUBLIC
# client with Direct Access Grants enabled.
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=candidate-app-dev
