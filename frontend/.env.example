# --- Public (exposed to browser) ---

# When true: the app uses in-memory mock data from src/mocks (offline mode).
# When false: real HTTP calls to Kong gateway with bearer JWT.
NEXT_PUBLIC_USE_MOCK=true

# Kong gateway base URL.
NEXT_PUBLIC_API_BASE_URL=https://api.job7189.com

# In-cluster fallback when running ssh / port-forward locally:
# NEXT_PUBLIC_API_BASE_URL=http://172.22.0.4:30003

# Some Kong routes are matched by Host header instead of FQDN.
# When non-empty, the api client adds `Host: <value>` to every request.
NEXT_PUBLIC_API_HOST_OVERRIDE=

# Keycloak (realm `job7189`).
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.job7189.com
NEXT_PUBLIC_KEYCLOAK_REALM=job7189
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=web-frontend

# --- Server-only (NextAuth) ---

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# Issuer URL used by NextAuth Keycloak provider — must match the `iss` claim
# inside the JWT so Kong's JWT plugin accepts it.
KEYCLOAK_ISSUER=https://auth.job7189.com/realms/job7189
KEYCLOAK_CLIENT_ID=web-frontend
KEYCLOAK_CLIENT_SECRET=
