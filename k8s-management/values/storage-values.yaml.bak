image:
  registry: docker-registry.registry.svc.cluster.local:5000
  repository: localhost:5000/job7189/storage-service
  tag: "v1.2.5"
  pullPolicy: IfNotPresent

service:
  type: ClusterIP
  port: 80

ingress:
  enabled: true
  host: "storage.job7189.local"

redis:
  enabled: true

env:
  APP_NAME: "Job7189 Storage Service"
  DB_CONNECTION: mysql
  DB_HOST: mysql.data.svc.cluster.local
  DB_PORT: "3306"
  DB_DATABASE: job7189
  # DB_USERNAME will be injected by Vault Agent
  # DB_PASSWORD will be injected by Vault Agent from database/creds/storage-service
  
  MINIO_ENDPOINT: "http://192.168.112.154:8080"
  # MINIO_KEY and MINIO_SECRET will be injected by Vault Agent from secret/data/storage-service
  
  MINIO_REGION: "us-east-1"
  MINIO_BUCKET: "job7189-storage"

  MINIO_URL: "http://s3.job7189.local"
  
  MINIO_USE_PATH_STYLE_ENDPOINT: "true"

  # AWS credentials will be injected by Vault Agent from secret/data/storage-service
  AWS_DEFAULT_REGION: "us-east-1"
  AWS_BUCKET: "job7189-storage"
  AWS_ENDPOINT: "http://192.168.112.154:8080"
  AWS_USE_PATH_STYLE_ENDPOINT: true

  # NEXTJS_INTERNAL_API_SECRET will be injected by Vault Agent from secret/data/storage-service

vault:
  extraSecret: true
  extraSecretTemplate: |
    {{- with secret "secret/data/storage-service" -}}
    MINIO_KEY="{{ .Data.data.MINIO_KEY }}"
    MINIO_SECRET="{{ .Data.data.MINIO_SECRET }}"
    AWS_ACCESS_KEY_ID="{{ .Data.data.MINIO_KEY }}"
    AWS_SECRET_ACCESS_KEY="{{ .Data.data.MINIO_SECRET }}"
    NEXTJS_INTERNAL_API_SECRET="{{ .Data.data.NEXTJS_INTERNAL_API_SECRET }}"
    {{ end }}


  # FILESYSTEM_DISK: s3
  
  # AWS_ACCESS_KEY_ID: "minioadmin"
  # AWS_SECRET_ACCESS_KEY: "minioadmin"
  # AWS_DEFAULT_REGION: "us-east-1"
  # AWS_BUCKET: "job7189-storage" # Tên bucket bạn vừa tạo
  
  # # Đường dẫn nội bộ để Laravel gọi MinIO (Nhanh hơn gọi qua domain public)
  # AWS_ENDPOINT: "http://minio:9000"
  
  # # Đường dẫn public để hiển thị ảnh trên web (Frontend dùng cái này)
  # AWS_URL: "http://s3.job7189.local"
  
  # # Bắt buộc để dùng MinIO thay vì AWS thật
  # AWS_USE_PATH_STYLE_ENDPOINT: "true"
  
