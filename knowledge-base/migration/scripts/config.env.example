# knowledge-base/migration/scripts/config.env.example
#
# Copy to `config.env` (gitignored) and edit to match your tailnet + auth.
# All scripts source this file via `load_config` in lib/common.sh.

# Your Tailscale domain (login.tailscale.com → DNS → "Tailnet name")
TAILNET_DOMAIN="<your-tailnet>.ts.net"

# Tailscale auth key (reusable, pre-shared, tagged tag:zta-cluster).
# Get from https://login.tailscale.com/admin/settings/keys
# Only needed by 01-host-prep.sh; can be exported via env instead of file.
TS_AUTHKEY=""

# Hostnames you set on each VM via `sudo hostnamectl set-hostname ...`
# Note: WORKER_HOSTNAMES accepts any number of worker hostnames. To bring a
# replacement data-tier VM online (e.g. swap srv04 -> srv05 because srv04
# is stuck behind double-NAT and Tailscale can't direct-P2P), append the
# new hostname here BEFORE running onboard-srv05.sh. The decommission
# script removes the old node only after the new one is Ready.
CP_HOSTNAME="7189srv01"
WORKER_HOSTNAMES="7189srv02 7189srv03 7189srv04"
DATA_NODE="7189srv04"

# Kubernetes / Cilium versions.
# IMPORTANT: scripts install kubeadm/kubelet/kubectl as BINARIES from
# https://dl.k8s.io/release/v${KUBE_VERSION}/bin/linux/<arch>/ — NOT via
# the apt repo, which Debian Trixie rejects (sqv blocks v3 GPG packets
# from 2026-02-01). Pick the latest 1.30.x patch you want pinned.
KUBE_VERSION="1.30.14"
KUBE_MINOR="1.30"
CILIUM_VERSION="1.19.1"
# Ancillary tooling pinned to versions known to work with KUBE_VERSION above
CRICTL_VERSION="v1.30.1"
CNI_PLUGINS_VERSION="v1.5.1"
KUBE_RELEASE_TEMPLATE_VERSION="v0.18.0"

# Networking (don't touch unless conflicts with Tailscale CGNAT 100.64/10)
POD_CIDR="10.244.0.0/16"
SVC_CIDR="10.96.0.0/12"

CLUSTER_NAME="job7189"

# Resource profile:
#   tight  — for srv04 = 4 GB (default for migration plan 2026-05-10)
#   normal — for srv04 = 6 GB (older plan, more headroom)
RESOURCE_PROFILE="tight"

# NodePorts (must match thesis evidence)
REGISTRY_NODEPORT="30005"
HTTP_NODEPORT="30003"
HTTPS_NODEPORT="30001"
